name: dockercompose5830173475617504219
services:
  sql-server:
    container_name: sql_server_container
    environment:
      ACCEPT_EULA: "Y"
      MSSQL_SA_PASSWORD: YourStrong@Password123
    healthcheck:
      test:
        - CMD-SHELL
        - /opt/mssql-tools18/bin/sqlcmd -S localhost -U sa -P "YourStrong@Password123" -C -Q "SELECT 1" || exit 1
      timeout: 5s
      interval: 10s
      retries: 15
      start_period: 30s
    image: mcr.microsoft.com/mssql/server:2022-latest
    networks:
      default: null
    ports:
      - mode: ingress
        target: 1433
        published: "1444"
        protocol: tcp
    volumes:
      - type: volume
        source: sqlserver_data
        target: /var/opt/mssql
        volume: {}
  web:
    build:
      context: C:\Users\user\source\repos\Maarif
      dockerfile: Presentation/Dockerfile
    depends_on:
      sql-server:
        condition: service_healthy
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ConnectionStrings__cString: Server=sql-server,1433;Database=MaarifDb;User Id=sa;Password=YourStrong@Password123;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=True
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8080"
        protocol: tcp
networks:
  default:
    name: dockercompose5830173475617504219_default
volumes:
  sqlserver_data:
    name: dockercompose5830173475617504219_sqlserver_data