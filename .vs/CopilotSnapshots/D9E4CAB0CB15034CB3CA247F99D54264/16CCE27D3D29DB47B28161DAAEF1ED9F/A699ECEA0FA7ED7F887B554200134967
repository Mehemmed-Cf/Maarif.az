@model Application.Modules.LessonSchedulesModule.Commands.LessonScheduleAddCommand.LessonScheduleAddRequest
@{
    ViewData["Title"] = "Create Lesson Schedule";
}

<div class="page-header">
    <div class="row align-items-end">
        <div class="col-lg-8">
            <div class="page-header-title">
                <div class="d-inline">
                    <h4>Create Lesson Schedule</h4>
                    <span>Create a new schedule parameter setting for system tracking.</span>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-header-breadcrumb">
                <ul class="breadcrumb-title">
                    <li class="breadcrumb-item" style="float: left;">
                        <a asp-controller="Dashboard" asp-action="Index"> <i class="feather icon-home"></i> </a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a asp-action="Index">Lesson Schedules</a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a href="#!">Create</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="row">
        <div class="col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h5>Lesson Schedule Information</h5>
                    <span>Details for creating a new lesson schedule.</span>
                </div>
                <div class="card-block">
                    <form method="post" asp-action="Create">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label text-right">Lesson</label>
                            <div class="col-sm-9">
                                <select class="form-control" asp-for="LessonId" asp-items="ViewBag.Lessons"></select>
                                <span asp-validation-for="LessonId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label text-right">Group</label>
                            <div class="col-sm-9">
                                <select class="form-control" asp-for="GroupId" asp-items="ViewBag.Groups"></select>
                                <span asp-validation-for="GroupId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label text-right">Day</label>
                            <div class="col-sm-9">
                                <select class="form-control" asp-for="DayOfWeek" asp-items="ViewBag.DayOfWeek"></select>
                                <span asp-validation-for="DayOfWeek" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label text-right">Start Time</label>
                            <div class="col-sm-9">
                                <input type="time" class="form-control" asp-for="StartTime">
                                <span asp-validation-for="StartTime" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label text-right">End Time</label>
                            <div class="col-sm-9">
                                <input type="time" class="form-control" asp-for="EndTime">
                                <span asp-validation-for="EndTime" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label text-right">Room (Otaq)</label>
                            <div class="col-sm-9">
                                <select class="form-control" asp-for="RoomId" asp-items="ViewBag.Rooms">
                                    <option value="">-- Otaq seçin --</option>
                                </select>
                                <span asp-validation-for="RoomId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label text-right">Lesson Type</label>
                            <div class="col-sm-9">
                                <select class="form-control" asp-for="LessonType" asp-items="ViewBag.LessonType"></select>
                                <span asp-validation-for="LessonType" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-sm-3 col-form-label text-right">Week Type</label>
                            <div class="col-sm-9">
                                <select class="form-control" asp-for="WeekType" asp-items="ViewBag.WeekType"></select>
                                <span asp-validation-for="WeekType" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-sm-12 text-right">
                                <button type="submit" class="btn btn-primary m-b-0">
                                    <i class="fa fa-save"></i> Yadda saxla
                                </button>
                                <a asp-action="Index" class="btn btn-inverse m-b-0">
                                    <i class="fa fa-arrow-left"></i> Ləğv et
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section addjs {
    <partial name="_ValidationScriptsPartial" />
}