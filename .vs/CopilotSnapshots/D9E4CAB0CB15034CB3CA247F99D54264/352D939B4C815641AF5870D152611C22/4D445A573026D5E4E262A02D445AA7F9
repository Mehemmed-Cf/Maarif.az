```razor
@model Application.Modules.LessonSchedulesModule.Queries.LessonScheduleGetByIdQuery.LessonScheduleGetByIdResponseDto
@{
    ViewData["Title"] = "Lesson Schedule Details";
}

<div class="page-header">
    <div class="row align-items-end">
        <div class="col-lg-8">
            <div class="page-header-title">
                <div class="d-inline">
                    <h4>Lesson Schedule Details</h4>
                    <span>Detailed view of the specific lesson schedule.</span>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-header-breadcrumb">
                <ul class="breadcrumb-title">
                    <li class="breadcrumb-item" style="float: left;">
                        <a asp-controller="Dashboard" asp-action="Index"> <i class="feather icon-home"></i> </a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a asp-action="Index">Lesson Schedules</a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a href="#!">Details</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="row">
        <div class="col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h5>Lesson Schedule Information</h5>
                    <span>General details about the schedule and assigned groups.</span>
                </div>
                <div class="card-block">
                    <h4 class="sub-title">Main Information</h4>
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <label class="control-label text-primary">Id</label>
                            <p class="form-control">@Model.Id</p>
                        </div>
                        <div class="col-sm-6">
                            <label class="control-label text-primary">Lesson</label>
                            <p class="form-control">@Model.LessonName</p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <label class="control-label text-primary">Group</label>
                            <p class="form-control">@Model.GroupName</p>
                        </div>
                        <div class="col-sm-6">
                            <label class="control-label text-primary">Day</label>
                            <p class="form-control">@Model.DayOfWeek</p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <label class="control-label text-primary">Start</label>
                            <p class="form-control">@Model.StartTime.ToString(@"hh\:mm")</p>
                        </div>
                        <div class="col-sm-6">
                            <label class="control-label text-primary">End</label>
                            <p class="form-control">@Model.EndTime.ToString(@"hh\:mm")</p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <label class="control-label text-primary">Lesson Type</label>
                            <p class="form-control">@Model.LessonType</p>
                        </div>
                        <div class="col-sm-6">
                            <label class="control-label text-primary">Week Type</label>
                            <p class="form-control">@Model.WeekType</p>
                        </div>
                    </div>

                    <div class="form-group text-right m-t-20">
                        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">
                            <i class="fa fa-pencil"></i> Edit Schedule
                        </a>
                        <a class="btn btn-primary" asp-action="Index">
                            <i class="fa fa-arrow-left"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
```