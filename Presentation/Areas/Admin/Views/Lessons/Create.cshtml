@using Application.Modules.LessonsModule.Commands.LessonAddCommand
@model LessonAddRequest
@{
    ViewData["Title"] = "Create Lesson";
}

<div class="page-header">
    <div class="row align-items-end">
        <div class="col-lg-8">
            <div class="page-header-title">
                <div class="d-inline">
                    <h4>Create New Lesson</h4>
                    <span>Assign a teacher to a specific subject to begin a new academic session.</span>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-header-breadcrumb">
                <ul class="breadcrumb-title">
                    <li class="breadcrumb-item" style="float: left;">
                        <a asp-controller="Dashboard" asp-action="Index"> <i class="feather icon-home"></i> </a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a asp-action="Index">Lessons</a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a href="#!">Create</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="row">
        <div class="col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h5>Lesson Assignment Form</h5>
                    <span>Please select the required fields to map a teacher to a subject.</span>
                </div>
                <div class="card-block">
                    <h4 class="sub-title">Basic Inputs</h4>
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-group row">
                            <label class="col-sm-2 col-form-label" asp-for="SubjectId">Subject</label>
                            <div class="col-sm-10">
                                <select class="form-control" asp-for="SubjectId"
                                        asp-items="ViewBag.Subjects">
                                    <option value="">-- Select Subject (Fənn seçin) --</option>
                                </select>
                                <span asp-validation-for="SubjectId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-sm-2 col-form-label" asp-for="TeacherId">Teacher</label>
                            <div class="col-sm-10">
                                <select class="form-control" asp-for="TeacherId"
                                        asp-items="ViewBag.Teachers">
                                    <option value="">-- Select Teacher (Müəllim seçin) --</option>
                                </select>
                                <span asp-validation-for="TeacherId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group text-right m-t-20">
                            <a asp-action="Index" class="btn btn-primary">Ləğv et (Cancel)</a>
                            <button type="submit" class="btn btn-success">Yadda saxla (Save)</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}