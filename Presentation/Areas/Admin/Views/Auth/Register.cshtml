@using Application.Modules.StudentsModule.Commands.StudentRegisterCommand
@model StudentRegisterRequest
@{
    ViewData["Title"] = "Qeydiyyat";
}

<div class="page-header">
    <div class="row align-items-end">
        <div class="col-lg-8">
            <div class="page-header-title">
                <div class="d-inline">
                    <h4>Qeydiyyat</h4>
                    <span>Şəxsiyyət vəsiqənizdəki məlumatları daxil edin</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="row justify-content-center">
        <div class="col-sm-6">
            <div class="card">
                <div class="card-block">

                    <div asp-validation-summary="All" class="alert alert-danger"></div>

                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-sm-12">
                                <div class="form-group">
                                    <label asp-for="SerialNumber">Sənədin seriya nömrəsi</label>
                                    <input type="text"
                                           class="form-control"
                                           asp-for="SerialNumber"
                                           placeholder="AZE1234567"
                                           autocomplete="off" />
                                    <span asp-validation-for="SerialNumber" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-sm-12">
                                <div class="form-group">
                                    <label asp-for="FinCode">FİN kod</label>
                                    <input type="text"
                                           class="form-control"
                                           asp-for="FinCode"
                                           placeholder="ABC1234"
                                           autocomplete="off"
                                           maxlength="7" />
                                    <span asp-validation-for="FinCode" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        7 simvol — hərf və rəqəmlərdən ibarət
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="form-group text-right">
                            <button type="submit" class="btn btn-success">
                                Şəxsi kabinet yarat
                            </button>
                        </div>
                    </form>

                    <div class="text-center mt-2">
                        <small>
                            Artıq hesabınız var?
                            <a asp-action="Login">Daxil olun</a>
                        </small>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}