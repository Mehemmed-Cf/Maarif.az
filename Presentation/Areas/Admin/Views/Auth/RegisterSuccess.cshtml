@{
    ViewData["Title"] = "Qeydiyyat tamamlandı";
}

<div class="page-header">
    <div class="row align-items-end">
        <div class="col-lg-8">
            <div class="page-header-title">
                <div class="d-inline">
                    <h4>Qeydiyyat tamamlandı</h4>
                    <span>Aşağıdakı məlumatlarla sistemə daxil ola bilərsiniz</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="row justify-content-center">
        <div class="col-sm-6">
            <div class="card">
                <div class="card-block text-center">

                    <i class="feather icon-check-circle text-success"
                       style="font-size: 48px;"></i>

                    <h5 class="mt-3">Qeydiyyat uğurla tamamlandı!</h5>
                    <p class="text-muted">
                        Sisteme daxil olmaq üçün aşağıdakı məlumatları istifadə edin.
                    </p>

                    <table class="table table-bordered mt-3 text-left">
                        <tr>
                            <th>Tələbə nömrəsi</th>
                            <td><strong>@ViewBag.StudentNumber</strong></td>
                        </tr>
                        <tr>
                            <th>İlkin şifrə</th>
                            <td><strong>@ViewBag.DefaultPassword</strong></td>
                        </tr>
                    </table>

                    <div class="alert alert-warning mt-3">
                        <i class="feather icon-alert-triangle"></i>
                        Sistemə daxil olduqdan sonra şifrənizi dəyişin.
                    </div>

                    <a asp-action="Login" class="btn btn-primary mt-2">
                        Daxil ol
                    </a>

                </div>
            </div>
        </div>
    </div>
</div>