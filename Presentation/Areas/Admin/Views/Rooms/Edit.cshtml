@model Application.Modules.RoomsModule.Commands.RoomEditCommand.RoomEditRequest
@{
    ViewData["Title"] = "Edit Room";
}

<div class="page-header">
    <div class="row align-items-end">
        <div class="col-lg-8">
            <div class="page-header-title">
                <div class="d-inline">
                    <h4>Edit Existing Room</h4>
                    <span>Modify floor parameters and building designations.</span>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-header-breadcrumb">
                <ul class="breadcrumb-title">
                    <li class="breadcrumb-item" style="float: left;">
                        <a asp-controller="Dashboard" asp-action="Index"> <i class="feather icon-home"></i> </a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a asp-action="Index">Rooms</a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a href="#!">Edit</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="row">
        <div class="col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h5>Edit Room Settings</h5>
                    <span>Ensure you enter correct mapping for updated classes.</span>
                </div>
                <div class="card-block">
                    <h4 class="sub-title">Structure Inputs</h4>
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="form-group row">
                            <label class="col-sm-2 col-form-label" asp-for="Number">Otaq Nömr?si</label>
                            <div class="col-sm-10">
                                <input type="number" class="form-control" asp-for="Number" />
                                <span asp-validation-for="Number" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-sm-2 col-form-label" asp-for="BuildingId">Korpus</label>
                            <div class="col-sm-10">
                                <select class="form-control" asp-for="BuildingId"
                                        asp-items="ViewBag.Buildings">
                                    <option value="">-- Select Korpus --</option>
                                </select>
                                <span asp-validation-for="BuildingId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group text-right m-t-20">
                            <a asp-action="Index" class="btn btn-primary">L??v et (Cancel)</a>
                            <button type="submit" class="btn btn-success">Yadda saxla (Save)</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
