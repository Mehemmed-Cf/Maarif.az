@using Application.Modules.StudentsModule.Commands.StudentAddCommand
@model StudentAddRequest
@{
    ViewData["Title"] = "Create Student";
}

<div class="page-header">
    <div class="row align-items-end">
        <div class="col-lg-8">
            <div class="page-header-title">
                <div class="d-inline">
                    <h4>Add Student</h4>
                    <span>Create a new student record</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="card">
        <div class="card-block">
            <form asp-action="Create" method="post">
                <div class="row">
                    <div class="col-sm-6">
                        <div class="form-group">
                            <label asp-for="FullName">Full Name</label>
                            <input type="text" class="form-control" asp-for="FullName">
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="form-group">
                            <label asp-for="StudentNumber">Student Number</label>
                            <input type="text" class="form-control" asp-for="StudentNumber">
                            <span asp-validation-for="StudentNumber" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="form-group">
                            <label asp-for="FatherName">Father Name</label>
                            <input type="text" class="form-control" asp-for="FatherName">
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="form-group">
                            <label asp-for="FinCode">FinCode</label>
                            <input type="text" class="form-control" asp-for="FinCode">
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group">
                            <label asp-for="Gender">Gender</label>
                            <select class="form-control" asp-for="Gender" asp-items="Html.GetEnumSelectList<Domain.Models.Stables.GenderType>()">
                                <option value="">-- Select --</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group">
                            <label asp-for="BirthDate">Birth Date</label>
                            <input type="date" class="form-control" asp-for="BirthDate">
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="form-group">
                            <label asp-for="MobileNumber">Mobile</label>
                            <input type="text" class="form-control" asp-for="MobileNumber">
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="form-group">
                            <label asp-for="DepartmentId">Department</label>
                            <select class="form-control" asp-for="DepartmentId" asp-items="ViewBag.Departments">
                                <option value="">-- Select --</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-sm-2">
                        <div class="form-group">
                            <label asp-for="Year">Year</label>
                            <input type="number" class="form-control" asp-for="Year">
                        </div>
                    </div>
                    <div class="col-sm-2">
                        <div class="form-group">
                            <label asp-for="Status">Status</label>
                            <select class="form-control" asp-for="Status" asp-items="Html.GetEnumSelectList<Domain.Models.Stables.StatusType>()"></select>
                        </div>
                    </div>
                    @* Add this inside the <div class="row"> in Create.cshtml *@
                    <div class="col-sm-2">
                        <div class="form-group">
                            <label asp-for="Grade">Grade</label>
                            <select class="form-control" asp-for="Grade"
                                    asp-items="Html.GetEnumSelectList<Domain.Models.Stables.GradeType>()">
                                <option value="">-- Select Grade --</option>
                            </select>
                            <span asp-validation-for="Grade" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group text-right">
                    <a asp-action="Index" class="btn btn-primary">Cancel</a>
                    <button type="submit" class="btn btn-success">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>