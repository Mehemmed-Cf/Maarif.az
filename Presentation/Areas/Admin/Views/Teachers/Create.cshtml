@using Application.Modules.TeachersModule.Commands.TeacherAddCommand
@model TeacherAddRequest
@{
    ViewData["Title"] = "Create";
}

<div class="page-header">
    <div class="row align-items-end">
        <div class="col-lg-8">
            <div class="page-header-title">
                <div class="d-inline">
                    <h4>Add Teacher</h4>
                    <span>Create a new teacher record</span>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-header-breadcrumb">
                <ul class="breadcrumb-title">
                    <li class="breadcrumb-item" style="float: left;">
                        <a href="../index.html"> <i class="feather icon-home"></i> </a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a href="#!">Teachers</a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a href="#!">Create</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="row">
        <div class="col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h5>Teacher Information</h5>
                    <span>Fill in the details for the new teacher</span>
                    <div class="card-header-right">
                        <i class="icofont icofont-spinner-alt-5"></i>
                    </div>
                </div>
                <div class="card-block">
                    <h4 class="sub-title">Basic Inputs</h4>
                    <form asp-action="Create" method="post">

                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label asp-for="FullName">Ad Soyad</label>
                                    <input type="text" class="form-control" asp-for="FullName"
                                           placeholder="Məsələn: Əli Həsənov">
                                    <span asp-validation-for="FullName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label asp-for="Email">Email</label>
                                    <input type="email" class="form-control" asp-for="Email"
                                           placeholder="Məsələn: teacher@university.edu">
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label asp-for="BirthDate">Doğum Tarixi</label>
                                    <input type="date" class="form-control" asp-for="BirthDate">
                                    <span asp-validation-for="BirthDate" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label asp-for="Experience">Təcrübə (il)</label>
                                    <input type="number" class="form-control" asp-for="Experience"
                                           placeholder="Məsələn: 5">
                                    <span asp-validation-for="Experience" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label asp-for="DepartmentIds">Departments</label>

                                    <select asp-for="DepartmentIds"
                                            asp-items="ViewBag.Departments"
                                            class="form-control"
                                            multiple>
                                    </select>

                                    <span asp-validation-for="DepartmentIds" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group text-right">
                            <a asp-action="Index" class="btn btn-sm btn-primary">Ləğv et</a>
                            <button type="submit" class="btn btn-sm btn-success">Yadda saxla</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section addcss {
    <link rel="stylesheet" href="~/libs/single-image-chooser/single-image-chooser.css" />
}
@section addjs {
    <script src="~/libs/ckeditor5/ckeditor.min.js"></script>
    <script src="~/libs/single-image-chooser/single-image-chooser.js"></script>
    <script>
        $(document).ready(function () {
            $('#cover-image').singleImageChooser();
        });
    </script>
}
