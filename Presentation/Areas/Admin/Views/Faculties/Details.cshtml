@using Application.Modules.FacultiesModule.Queries.FacultyGetByIdQuery
@model FacultyGetByIdResponseDto
@{
    ViewData["Title"] = "Details";
}

<div class="page-header">
    <div class="row align-items-end">
        <div class="col-lg-8">
            <div class="page-header-title">
                <div class="d-inline">
                    <h4>Basic Form Inputs</h4>
                    <span>
                        Lorem ipsum dolor sit <code>amet</code>, consectetur
                        adipisicing elit
                    </span>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-header-breadcrumb">
                <ul class="breadcrumb-title">
                    <li class="breadcrumb-item" style="float: left;">
                        <a href="../index.html"> <i class="feather icon-home"></i> </a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a href="#!">Form Components</a>
                    </li>
                    <li class="breadcrumb-item" style="float: left;">
                        <a href="#!">Form Components</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>


<div class="page-body">
    <div class="row">
        <div class="col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h5>Basic Form Inputs</h5>
                    <span>
                        Add class of <code>.form-control</code> with
                        <code>&lt;input&gt;</code> tag
                    </span>


                    <div class="card-header-right">
                        <i class="icofont icofont-spinner-alt-5"></i>
                    </div>

                </div>
                <div class="card-block">
                    <h4 class="sub-title">Basic Inputs</h4>

                        <div class="card-block">
                            <h4 class="sub-title">Fakültə Məlumatları</h4>

                            <div class="form-row">
                                <div class="col-sm-12">
                                    <div class="form-group">
                                        <label class="control-label" asp-for="Name">Fakültə Adı</label>
                                        <p class="form-control">@Model.Name</p>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="control-label">Bağlı Kafedralar (Departments)</label>
                                <div class="border p-3 bg-light rounded">
                                    @if (Model.Departments != null && Model.Departments.Any())
                                    {
                                        <ul class="list-unstyled mb-0">
                                            @foreach (var dept in Model.Departments)
                                            {
                                                <li class="mb-2 d-flex align-items-center">
                                                    <i class="feather icon-check-circle text-primary mr-2"></i>
                                                    <strong>@dept.DepartmentName</strong>
                                                    <span class="text-muted ml-2">(ID: @dept.Id)</span>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <span class="text-muted italic">Bu fakültəyə hələ heç bir kafedra əlavə edilməyib.</span>
                                    }
                                </div>
                            </div>
                        </div>


                        <div class="form-group text-right m-0">
                            <input type="hidden" class="form-control" asp-for="Id">
                            <a class="btn btn-sm btn-warning" asp-action="edit" asp-route-id="@Model.Id">Edit</a>
                            <a class="btn btn-sm btn-primary" asp-action="index">Cancel</a>
                        </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section addcss {
    <link rel="stylesheet" href="~/libs/single-image-chooser/single-image-chooser.css" />
}

@section addjs {
    <script src="~/libs/ckeditor5/ckeditor.min.js"></script>
    <script src="~/libs/single-image-chooser/single-image-chooser.js"></script>
    <script>
        $(document).ready(function () {

            $('#cover-image').singleImageChooser();

            ClassicEditor
                .create(document.querySelector('#body-editor'))
                .then(editor => { })
                .catch(error => { console.error(error); });

        });
    </script>
}