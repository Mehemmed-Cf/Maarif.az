@{
    Layout = null;
    var fullName = ViewBag.PortalFullName as string ?? "";
    var badge = ViewBag.PortalBadge as string ?? "";
    var initials = ViewBag.PortalInitials as string ?? PortalText.InitialsFrom(fullName);
    var active = ViewBag.PortalActiveNav as string ?? "schedule";
    var isTeacher = ViewBag.PortalIsTeacher as bool? ?? false;
    var portalController = isTeacher ? "TeacherPortal" : "Portal";
    var brandSub = isTeacher ? "Müəllim kabineti" : "Tələbə portalı";
    var brandIcon = isTeacher ? "ph-chalkboard-teacher" : "ph-student";
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Maarif — portal">
    <title>@(ViewBag.Title ?? "Portal") — Maarif</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@@phosphor-icons/web"></script>
    <style>
        :root {
            --primary:        #0284c7;
            --primary-light:  #f0f9ff;
            --primary-hover:  #0369a1;
            --bg-body:        #f8fafc;
            --bg-surface:     #ffffff;
            --text-main:      #1e293b;
            --text-muted:     #64748b;
            --text-light:     #94a3b8;
            --border:         #f1f5f9;
            --lecture-bg:      #eff6ff; --lecture-border:    #3b82f6; --lecture-text:    #1d4ed8;
            --lab-bg:          #fdf4ff; --lab-border:        #d946ef; --lab-text:        #a21caf;
            --practical-bg:    #f0fdf4; --practical-border:  #22c55e; --practical-text:  #15803d;
            --seminar-bg:      #fff7ed; --seminar-border:    #f97316; --seminar-text:    #c2410c;
            --shadow-sm:   0 1px 2px 0 rgb(0 0 0/.05);
            --shadow-card: 0 10px 25px -5px rgb(0 0 0/.03), 0 8px 10px -6px rgb(0 0 0/.03);
            --shadow-hover: 0 20px 25px -5px rgb(0 0 0/.08), 0 8px 10px -6px rgb(0 0 0/.03);
        }
        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            display: flex;
            height: 100vh;
            overflow: hidden;
            -webkit-font-smoothing: antialiased;
        }
        .sidebar {
            width: 280px;
            background: var(--bg-surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            z-index: 10;
            flex-shrink: 0;
        }
        .brand {
            padding: 24px 28px;
            display: flex;
            align-items: center;
            gap: 14px;
            border-bottom: 1px solid var(--border);
        }
        .brand-logo {
            width: 44px; height: 44px;
            background: linear-gradient(135deg, var(--primary), #38bdf8);
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 24px;
            box-shadow: 0 4px 12px rgba(2,132,199,.2);
            flex-shrink: 0;
        }
        .brand-title   { font-weight:700; font-size:1.15rem; color:var(--text-main); letter-spacing:-.02em; }
        .brand-subtitle{ font-size:.75rem; color:var(--text-muted); font-weight:500; }
        .nav-menu {
            flex: 1;
            padding: 24px 16px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .nav-item {
            display: flex; align-items: center; gap: 14px;
            padding: 12px 16px;
            border-radius: 12px;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            font-size: .95rem;
            transition: all .2s;
        }
        .nav-item i { font-size:1.3rem; }
        .nav-item:hover:not(.active) { background: var(--border); color: var(--text-main); }
        .nav-item.active { background: var(--primary-light); color: var(--primary); font-weight:600; }
        .nav-item.muted { opacity: .45; pointer-events: none; cursor: default; }
        .sidebar-footer { padding: 24px; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 12px; }
        .term-info {
            background: linear-gradient(145deg, #f8fafc, #f1f5f9);
            padding: 16px; border-radius: 16px; border: 1px solid var(--border);
            display: flex; align-items: center; gap: 12px;
        }
        .term-icon {
            background: white; width:32px; height:32px; border-radius:8px;
            display:flex; align-items:center; justify-content:center;
            color:var(--primary); font-size:1.1rem; box-shadow:var(--shadow-sm); flex-shrink:0;
        }
        .term-text p { font-size:.75rem; color:var(--text-muted); font-weight:500; }
        .term-text h6 { font-size:.85rem; color:var(--text-main); font-weight:700; }
        .btn-logout {
            display:flex; align-items:center; justify-content:center; gap:8px;
            width:100%; padding:12px; border-radius:12px; border:1px solid var(--border);
            background:var(--bg-surface); color:var(--text-muted); font-family:inherit; font-weight:600;
            font-size:.9rem; cursor:pointer; transition:background .2s, color .2s;
        }
        .btn-logout:hover { background:var(--border); color:var(--text-main); }
        .main-wrapper { flex:1; display:flex; flex-direction:column; min-width:0; }
        .topbar {
            height:80px;
            background: rgba(255,255,255,.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 40px;
            position: sticky; top:0; z-index:5;
            flex-shrink: 0;
        }
        .breadcrumb { display:flex; align-items:center; gap:10px; font-size:.9rem; color:var(--text-light); font-weight:500; flex-wrap:wrap; }
        .breadcrumb span.current { color:var(--text-main); font-weight:600; }
        .breadcrumb i { font-size:.8rem; }
        .topbar-actions { display:flex; align-items:center; gap:20px; }
        .profile {
            display:flex; align-items:center; gap:14px;
            padding-left:20px; border-left:1px solid var(--border);
        }
        .profile-info { text-align:right; }
        .profile-name { font-size:.95rem; font-weight:600; color:var(--text-main); }
        .profile-id   { font-size:.75rem; color:var(--text-muted); font-weight:500; }
        .avatar-circle {
            width:44px; height:44px; border-radius:14px;
            background: linear-gradient(135deg, #0284c7, #38bdf8);
            display:flex; align-items:center; justify-content:center;
            color:white; font-weight:700; font-size:.95rem;
            letter-spacing:-.02em;
            box-shadow:var(--shadow-sm); flex-shrink:0;
            user-select:none;
        }
        .content { flex:1; padding:36px 40px; overflow-y:auto; }
    </style>
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <aside class="sidebar">
        <div class="brand">
            <div class="brand-logo"><i class="ph-fill @brandIcon"></i></div>
            <div>
                <div class="brand-title">Maarif</div>
                <div class="brand-subtitle">@brandSub</div>
            </div>
        </div>
        <nav class="nav-menu">
            <span class="nav-item muted"><i class="ph ph-squares-four"></i>İdarə paneli</span>
            <span class="nav-item muted"><i class="ph ph-megaphone"></i>Elanlar</span>
            <a asp-controller="@portalController" asp-action="Profile" class="nav-item @(active == "profile" ? "active" : "")"><i class="ph ph-user-circle"></i>Şəxsi məlumat</a>
            <a asp-controller="@portalController" asp-action="Index" class="nav-item @(active == "schedule" ? "active" : "")"><i class="ph ph-calendar-blank"></i>Dərs cədvəli</a>
            @if (isTeacher)
            {
                <a asp-controller="Auth" asp-action="TeacherChangePassword" class="nav-item @(active == "password" ? "active" : "")"><i class="ph ph-key"></i>Şifrəni dəyiş</a>
            }
            else
            {
                <a asp-controller="Auth" asp-action="StudentChangePassword" class="nav-item @(active == "password" ? "active" : "")"><i class="ph ph-key"></i>Şifrəni dəyiş</a>
            }
            <span class="nav-item muted"><i class="ph ph-books"></i>Fənlər</span>
            <span class="nav-item muted"><i class="ph ph-clipboard-text"></i>Tapşırıqlar</span>
        </nav>
        <div class="sidebar-footer">
            <div class="term-info">
                <div class="term-icon"><i class="ph-fill ph-calendar-check"></i></div>
                <div class="term-text">
                    <p>Cari semestr</p>
                    <h6>Yaz 2026</h6>
                </div>
            </div>
            <form asp-controller="Auth" asp-action="Logout" asp-route-returnPortal="@(isTeacher ? "teacher" : "student")" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout"><i class="ph ph-sign-out"></i> Çıxış</button>
            </form>
        </div>
    </aside>
    <div class="main-wrapper">
        <header class="topbar">
            <div class="breadcrumb">
                <i class="ph-fill ph-house"></i>
                <span>Portal</span>
                <i class="ph-bold ph-caret-right"></i>
                <span class="current">@ViewBag.PortalBreadcrumb</span>
            </div>
            <div class="topbar-actions">
                <div class="profile">
                    <div class="profile-info">
                        <div class="profile-name">@fullName</div>
                        <div class="profile-id">@badge</div>
                    </div>
                    <div class="avatar-circle" title="@fullName">@initials</div>
                </div>
            </div>
        </header>
        <main class="content">
            @RenderBody()
        </main>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
