@using Application.Modules.StudentsModule.Commands.StudentRegisterCommand
@model StudentRegisterRequest
@{
    ViewData["Title"] = "Qeydiyyat";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div asp-validation-summary="All" class="alert alert-danger"></div>

<form asp-action="Register" method="post">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label asp-for="SerialNumber">Sənədin seriya nömrəsi</label>
        <input type="text" class="form-control" asp-for="SerialNumber"
               placeholder="AZE1234567" autocomplete="off" />
        <span asp-validation-for="SerialNumber" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="FinCode">FİN kod</label>
        <input type="text" class="form-control" asp-for="FinCode"
               placeholder="ABC1234" autocomplete="off" maxlength="7" />
        <span asp-validation-for="FinCode" class="text-danger"></span>
        <div class="small-hint">7 simvol — hərf və rəqəmlərdən ibarət</div>
    </div>
    <button type="submit" class="btn-auth">Şəxsi kabinet yarat</button>
</form>

<div class="auth-footer">
    Artıq hesabınız var? <a asp-action="Login">Daxil olun</a>
    &nbsp;·&nbsp;
    <a asp-action="TeacherRegister">Müəllim qeydiyyatı</a>
    <br /><br />
    <a asp-action="ForgotStudentPassword">Şifrəni unutdum</a>
    &nbsp;·&nbsp;
    <a asp-action="RecoverStudentNumber">Nömrəmi unutdum</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}