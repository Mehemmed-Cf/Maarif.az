@using Application.Modules.TeachersModule.Commands.TeacherChangePasswordCommand
@model TeacherChangePasswordRequest
@{
    Layout = "~/Views/Shared/_AcademicPortalLayout.cshtml";
}

@section Head {
<style>
    .pwd-form { max-width: 440px; }
    .pwd-form .field-row { display: flex; flex-direction: column; gap: 8px; margin-bottom: 18px; }
    .pwd-form label { font-weight: 600; font-size: .9rem; color: var(--text-muted); }
    .pwd-form input {
        width: 100%; padding: 12px 14px; border-radius: 12px; border: 1px solid var(--border);
        font-family: inherit; font-size: .95rem;
    }
    .pwd-form .btn-submit {
        margin-top: 8px; width: 100%; padding: 14px; border: none; border-radius: 12px;
        background: var(--primary); color: white; font-weight: 700; font-family: inherit; cursor: pointer;
    }
    .pwd-form .btn-submit:hover { background: var(--primary-hover); }
    .alert-ok { background: #ecfdf5; border: 1px solid #6ee7b7; color: #047857; padding: 12px 14px; border-radius: 12px; margin-bottom: 20px; font-size: .9rem; }
</style>
}

@if (TempData["PasswordMessage"] is string okMsg)
{
    <div class="alert-ok">@okMsg</div>
}

<div asp-validation-summary="All" class="alert alert-danger" style="margin-bottom:1rem;padding:12px;border-radius:12px;"></div>

<div class="pwd-form">
    <h1 style="font-size:1.35rem;font-weight:700;margin-bottom:8px;">Şifrəni dəyiş</h1>
    <p style="color:var(--text-muted);font-size:.95rem;margin-bottom:24px;">Cari şifrənizi və yeni şifrənizi daxil edin.</p>

    <form asp-action="TeacherChangePassword" method="post">
        @Html.AntiForgeryToken()
        <div class="field-row">
            <label asp-for="CurrentPassword"></label>
            <input asp-for="CurrentPassword" autocomplete="current-password" />
            <span asp-validation-for="CurrentPassword" class="text-danger" style="font-size:.85rem;"></span>
        </div>
        <div class="field-row">
            <label asp-for="NewPassword"></label>
            <input asp-for="NewPassword" autocomplete="new-password" />
            <span asp-validation-for="NewPassword" class="text-danger" style="font-size:.85rem;"></span>
        </div>
        <div class="field-row">
            <label asp-for="ConfirmNewPassword"></label>
            <input asp-for="ConfirmNewPassword" autocomplete="new-password" />
            <span asp-validation-for="ConfirmNewPassword" class="text-danger" style="font-size:.85rem;"></span>
        </div>
        <button type="submit" class="btn-submit">Yenilə</button>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
