@using Application.Modules.TeachersModule.Commands.TeacherLoginCommand
@model TeacherLoginRequest

@{
    ViewData["Title"] = "Müəllim — daxil ol";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

@if (TempData["AuthInfo"] is string info)
{
    <div class="alert alert-success" style="margin-bottom:16px;">@info</div>
}

<div asp-validation-summary="All" class="alert alert-danger"></div>

<form asp-action="TeacherLogin" method="post">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label asp-for="TeacherNumber">Müəllim nömrəsi</label>
        <input type="text" class="form-control" asp-for="TeacherNumber"
               placeholder="T20260405123" autocomplete="username" />
        <span asp-validation-for="TeacherNumber" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Password">Şifrə</label>
        <input type="password" class="form-control" asp-for="Password"
               autocomplete="current-password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>
    <button type="submit" class="btn-auth">Daxil ol</button>
</form>

<div class="auth-footer">
    Hesabınız yoxdur? <a asp-action="TeacherRegister">Qeydiyyat</a>
    &nbsp;·&nbsp;
    <a asp-action="Login">Tələbə girişi</a>
    <br /><br />
    <a asp-action="ForgotTeacherPassword">Şifrəni unutdum</a>
    &nbsp;·&nbsp;
    <a asp-action="RecoverTeacherNumber">Nömrəmi unutdum</a>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
