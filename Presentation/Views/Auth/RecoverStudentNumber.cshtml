@using Application.Modules.StudentsModule.Commands.RecoverStudentNumberCommand
@model RecoverStudentNumberRequest
@{
    ViewData["Title"] = "Tələbə nömrəsi";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-logo">
    <div class="logo-icon"><i class="feather icon-hash"></i></div>
    <h4>Tələbə nömrəmini xatırla</h4>
    <p>FIN və sənəd seriyası eyni qeydiyyatda olduğu kimidir</p>
</div>

<div asp-validation-summary="All" class="alert alert-danger"></div>

<form asp-action="RecoverStudentNumber" method="post">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label asp-for="SerialNumber">Sənədin seriya nömrəsi</label>
        <input type="text" class="form-control" asp-for="SerialNumber" autocomplete="off" />
        <span asp-validation-for="SerialNumber" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="FinCode">FİN kod</label>
        <input type="text" class="form-control" asp-for="FinCode" maxlength="7" autocomplete="off" />
        <span asp-validation-for="FinCode" class="text-danger"></span>
    </div>
    <button type="submit" class="btn-auth">Nömrəni göstər</button>
</form>

<div class="auth-footer">
    <a asp-action="Login">Giriş</a>
    &nbsp;·&nbsp;
    <a asp-action="ForgotStudentPassword">Şifrəni unutdum</a>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
