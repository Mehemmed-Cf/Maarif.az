@using Application.Modules.AdminModule.Commands.AdminLoginCommand
@model AdminLoginRequest

@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewData["Title"] - LMS Administrasiyası</title>
    <!-- Meta -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    <!-- Google font-->     
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,600" rel="stylesheet">
    <!-- Required Fremwork -->
    <link rel="stylesheet" type="text/css" href="~/libs/bootstrap/dist/css/bootstrap.min.css">
    <!-- Style.css -->
    <link rel="stylesheet" type="text/css" href="~/admin/css/style.css">
    <link rel="stylesheet" type="text/css" href="~/admin/icon/feather/css/feather.css">
</head>

<body class="fix-menu">
    <section class="login-block">
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-12">
                    
                    <form class="md-float-material form-material" asp-action="AdminLogin" method="post" asp-route-returnUrl="@ViewData["ReturnUrl"]">
                        @Html.AntiForgeryToken()
                        
                        <div class="text-center">
                            <img src="~/admin/images/logo.png" alt="logo.png">
                        </div>
                        
                        <div class="auth-box card">
                            <div class="card-block">
                                <div class="row m-b-20">
                                    <div class="col-md-12">
                                        <h3 class="text-center txt-primary">Admin İdarəetmə Paneli</h3>
                                    </div>
                                </div>
                                
                                <div asp-validation-summary="All" class="text-danger"></div>

                                @if (ViewData["AlreadySignedInAsNonAdmin"] as bool? == true)
                                {
                                    <div class="alert alert-warning small m-b-20">
                                        Hazırda başqa rol ilə daxil olmusunuz. Admin hesabı ilə davam etmək üçün
                                        <a asp-action="EndSessionForAdmin">buradan çıxış edin</a>, sonra yenidən daxil olun.
                                    </div>
                                }
                                
                                <div class="form-group form-primary">
                                    <input type="email" asp-for="Email" class="form-control" required placeholder="Email">
                                    <span class="form-bar"></span>
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                                <div class="form-group form-primary">
                                    <input type="password" asp-for="Password" class="form-control" required placeholder="Şifrə">
                                    <span class="form-bar"></span>
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>
                                
                                <div class="row m-t-25 text-left">
                                    <div class="col-12">
                                        <div class="checkbox-fade fade-in-primary">
                                            <label>
                                                <input type="checkbox" asp-for="RememberMe">
                                                <span class="cr"><i class="cr-icon icofont icofont-ui-check txt-primary"></i></span>
                                                <span class="text-inverse">Məni xatırla</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row m-t-30">
                                    <div class="col-md-12">
                                        <button type="submit" class="btn btn-primary btn-md btn-block waves-effect text-center m-b-20">Daxil Ol</button>
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                    </form>
                    
                </div>
            </div>
        </div>
    </section>

    <!-- Required Jquery -->
    <script type="text/javascript" src="~/libs/jquery/jquery.min.js"></script>
    <script type="text/javascript" src="~/libs/bootstrap/dist/js/bootstrap.min.js"></script>
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
</body>
</html>
