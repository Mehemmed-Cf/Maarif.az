@{
    ViewData["Title"] = "Qeydiyyat tamamlandı";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="text-center mb-4">
    <div style="width:72px;height:72px;background:linear-gradient(135deg,#00b09b,#96c93d);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;margin-bottom:16px;">
        <i class="feather icon-check" style="font-size:32px;color:#fff;"></i>
    </div>
    <h5 style="font-weight:700;color:#1a1a2e;margin-bottom:6px;">Qeydiyyat uğurla tamamlandı!</h5>
    <p style="font-size:13px;color:#888;margin:0;">
        Aşağıdakı məlumatlarla sistemə daxil ola bilərsiniz.
    </p>
</div>

<div style="background:#f8f9ff;border-radius:12px;padding:20px;margin-bottom:20px;">
    <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid #eee;">
        <span style="font-size:13px;color:#888;font-weight:600;">Tələbə nömrəsi</span>
        <span style="font-size:15px;font-weight:700;color:#1a1a2e;letter-spacing:1px;">@ViewBag.StudentNumber</span>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;">
        <span style="font-size:13px;color:#888;font-weight:600;">İlkin şifrə</span>
        <span style="font-size:15px;font-weight:700;color:#1a1a2e;letter-spacing:1px;">@ViewBag.DefaultPassword</span>
    </div>
</div>

<div style="background:#fff8e1;border-radius:10px;padding:14px 16px;margin-bottom:24px;display:flex;align-items:flex-start;gap:10px;">
    <i class="feather icon-alert-triangle" style="color:#f39c12;font-size:18px;margin-top:1px;flex-shrink:0;"></i>
    <span style="font-size:13px;color:#7d6608;">
        Sistemə daxil olduqdan sonra təhlükəsizlik üçün şifrənizi dəyişin.
    </span>
</div>

<a asp-action="Login" class="btn-auth" style="display:block;text-align:center;text-decoration:none;line-height:48px;">
    Daxil ol
</a>

<div class="auth-footer">
    <a asp-action="Register">Yeni qeydiyyat</a>
</div>