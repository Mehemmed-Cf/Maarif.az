@model Application.Modules.TeachersModule.Queries.GetTeacherPortalProfileQuery.TeacherPortalProfileDto
@using Presentation.AppCode
@{
    ViewBag.Title = "Şəxsi məlumat";
    ViewBag.PortalFullName = Model.FullName;
    ViewBag.PortalBadge = Model.TeacherNumber;
    ViewBag.PortalInitials = PortalText.InitialsFrom(Model.FullName);
    ViewBag.PortalActiveNav = "profile";
    ViewBag.PortalIsTeacher = true;
    ViewBag.PortalBreadcrumb = "Şəxsi məlumat";
}

@section Head {
<style>
    .profile-hero {
        position: relative;
        margin: -12px -8px 32px -8px;
        padding: 48px 40px 56px 40px;
        border-radius: 0 0 24px 24px;
        background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 40%, #6366f1 100%);
        color: #fff;
        display: flex;
        align-items: flex-end;
        gap: 28px;
        flex-wrap: wrap;
    }
    .profile-hero-avatar {
        width: 96px; height: 96px; border-radius: 24px;
        background: rgba(255,255,255,.18);
        border: 3px solid rgba(255,255,255,.35);
        display: flex; align-items: center; justify-content: center;
        font-size: 2rem; font-weight: 800;
        margin-top: -72px;
        box-shadow: 0 12px 32px rgba(0,0,0,.2);
    }
    .profile-hero-text h1 { font-size: 1.65rem; font-weight: 700; margin-bottom: 6px; }
    .profile-hero-text p { font-size: .95rem; opacity: .92; font-weight: 500; }
    .profile-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        align-items: start;
    }
    @@media (max-width: 960px) { .profile-grid { grid-template-columns: 1fr; } }
    .info-card {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 28px;
        box-shadow: var(--shadow-card);
    }
    .info-card h2 {
        font-size: 1.1rem; font-weight: 700; color: var(--text-main);
        margin-bottom: 22px;
        padding-bottom: 14px;
        border-bottom: 2px solid var(--border);
    }
    .field-row {
        display: grid;
        grid-template-columns: minmax(120px, 38%) 1fr;
        gap: 16px;
        align-items: center;
        padding: 14px 0;
        border-bottom: 1px solid var(--border);
        font-size: .95rem;
    }
    .field-row:last-child { border-bottom: none; }
    .field-label { color: var(--text-muted); font-weight: 600; }
    .field-value {
        background: #f8fafc;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 12px 14px;
        color: var(--text-main);
        font-weight: 500;
    }
    .metrics {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    @@media (max-width: 520px) { .metrics { grid-template-columns: 1fr; } }
    .metric-tile {
        border-radius: 16px;
        padding: 22px;
        background: linear-gradient(145deg, #f0f9ff, #e0f2fe);
        border: 1px solid rgba(2,132,199,.15);
        text-align: center;
    }
    .metric-tile .num { font-size: 1.85rem; font-weight: 800; color: #0369a1; line-height: 1.2; }
    .metric-tile .lbl { font-size: .82rem; color: var(--text-muted); font-weight: 600; margin-top: 6px; }
    .dept-chips { display: flex; flex-wrap: wrap; gap: 10px; }
    .dept-chip {
        background: var(--primary-light);
        color: var(--primary);
        font-weight: 600;
        font-size: .88rem;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid rgba(2,132,199,.2);
    }
</style>
}

<div class="profile-hero">
    <div class="profile-hero-avatar">@PortalText.InitialsFrom(Model.FullName)</div>
    <div class="profile-hero-text">
        <h1>@Model.FullName</h1>
        <p>Müəllim nömrəsi: <strong>@Model.TeacherNumber</strong></p>
    </div>
</div>

<div class="profile-grid">
    <div class="info-card">
        <h2>Əlaqə və təcrübə</h2>
        <div class="field-row">
            <span class="field-label">E-poçt</span>
            <div class="field-value">@Model.Email</div>
        </div>
        <div class="field-row">
            <span class="field-label">Mobil</span>
            <div class="field-value">@Model.MobileNumber</div>
        </div>
        <div class="field-row">
            <span class="field-label">Doğum tarixi</span>
            <div class="field-value">@Model.BirthDateDisplay</div>
        </div>
        <div class="field-row">
            <span class="field-label">Staj</span>
            <div class="field-value">@Model.ExperienceDisplay</div>
        </div>
    </div>

    <div class="info-card">
        <h2>İş yükü (qısa)</h2>
        <div class="metrics">
            <div class="metric-tile">
                <div class="num">@Model.ActiveLessonCount</div>
                <div class="lbl">Aktiv fən / dərs</div>
            </div>
            <div class="metric-tile">
                <div class="num">@Model.DistinctGroupCount</div>
                <div class="lbl">Qrup sayı</div>
            </div>
        </div>
        <h2 style="margin-top:28px;">Əlaqəli şöbələr</h2>
        @if (Model.DepartmentsDisplay == "—")
        {
            <p class="field-value" style="border-style:dashed;">Hələ şöbə təyinatı yoxdur.</p>
        }
        else
        {
            <div class="dept-chips">
                @foreach (var d in Model.DepartmentsDisplay.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
                {
                    <span class="dept-chip">@d</span>
                }
            </div>
        }
    </div>
</div>
